# Root compose env — populates ${VAR} substitutions in docker-compose.yml
# and Caddyfile. Copy to `.env` (gitignored) before running compose.

# Image to pull. Set to your registry path once you publish:
#   ghcr.io/<owner>/stampee-api:<sha>
API_IMAGE=stampee-api:dev

# Domains Caddy serves. All three resolve to the VM's public IP.
SPA_DOMAIN=lealtad.example.com
API_DOMAIN=api.lealtad.example.com
CMS_DOMAIN=cms.example.com

# Used by Let's Encrypt for issuance + renewal notices.
ACME_EMAIL=ops@example.com

# Host path where the built SPA dist lives. Atomic deploys swap a symlink
# pointing here (see infra/README.md).
SPA_DIST_DIR=/srv/spa
