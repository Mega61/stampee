# Environment variables for the Stampee stack (docker-compose.prod.yml).
#
# In Portainer: set these under the stack's "Environment variables" section
# (no .env file needed). For CLI deploys you can instead copy this to .env.prod
# and run: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
#
# --- Required ---
STAMPEE_DB_PASSWORD=          # password of the loyalty_user role (QUICKSTART §2)
JWT_ACCESS_SECRET=            # >=32 random chars
JWT_REFRESH_SECRET=           # >=32 random chars

# --- Optional (have sensible defaults in the compose file) ---
# STAMPEE_DB_USER=loyalty_user
# STAMPEE_DB_NAME=stampee
# STAMPEE_DB_HOST=postgres-transversal
# RESEND_API_KEY=             # set with EMAIL_ADAPTER=resend for real emails
# GCS_BUCKET=                 # set when enabling image uploads (QUICKSTART §8)
# GCS_PROJECT_ID=
