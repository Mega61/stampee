# Compose substitution env for docker-compose.prod.yml on the shared VM.
# Copy to .env.prod (gitignored) and fill in. Discover the network names with
# `docker network ls`.

# The API image you built/pulled:  docker build -f infra/Dockerfile.api -t stampee-api:0.1.0 .
API_IMAGE=stampee-api:0.1.0

# Name of the external Docker network your Caddy reverse proxy is attached to.
WEB_NETWORK=

# Name of the external Docker network your shared Postgres is attached to.
DATA_NETWORK=
