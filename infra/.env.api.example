# API service env. Copy to .env.api (gitignored).
# Values you MUST set: JWT_*, RESEND_API_KEY, SPA_ORIGIN, APP_PUBLIC_URL, API_PUBLIC_URL,
# DATABASE_URL, GCS_BUCKET, GCS_PROJECT_ID.

NODE_ENV=production
PORT=3001

# Both URLs are public-facing (with scheme). SPA_ORIGIN is used for CORS;
# APP_PUBLIC_URL is used in email link templates; API_PUBLIC_URL is used in
# the verify-email link target.
SPA_ORIGIN=https://lealtad.example.com
APP_PUBLIC_URL=https://lealtad.example.com
API_PUBLIC_URL=https://api.lealtad.example.com

# Postgres on the same compose network. `postgres` is the service name.
# Replace with the same credentials you put in .env.postgres.
DATABASE_URL=postgres://loyalty_user:change-me-to-a-long-random-string@postgres:5432/appdb
PG_POOL_SIZE=10

# JWT — both must be >=32 chars. Rotate on suspected compromise; rotation
# invalidates every active session.
JWT_ACCESS_SECRET=replace-me-with-a-32-or-more-char-random-secret-aaa
JWT_REFRESH_SECRET=replace-me-with-a-32-or-more-char-random-secret-bbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cookies cross subdomains: leading dot so both SPA and API receive them.
COOKIE_DOMAIN=.lealtad.example.com
COOKIE_SECURE=true

BCRYPT_COST=12
PIN_BCRYPT_COST=10

# Email — Resend transactional API. Adapter=resend in prod, console in staging.
RESEND_API_KEY=re_replace_with_your_resend_key
EMAIL_FROM=Stampee <no-reply@lealtad.example.com>
EMAIL_ADAPTER=resend

# Google Cloud Storage. Authentication = ADC via the VM's attached service
# account (`media-writer`); leave GOOGLE_APPLICATION_CREDENTIALS empty.
GCS_BUCKET=gbs-apps-media
GCS_PROJECT_ID=gbs-infra
GOOGLE_APPLICATION_CREDENTIALS=
GCS_PUBLIC_HOST=https://storage.googleapis.com

# Google Workspace SSO ("Sign in with Google"). Leave empty to disable.
# GOOGLE_CLIENT_ID is the OAuth Web client ID (same value baked into the SPA).
# GOOGLE_WORKSPACE_DOMAIN is the allowed Workspace domain(s); consumer Gmail is rejected.
GOOGLE_CLIENT_ID=
GOOGLE_WORKSPACE_DOMAIN=goldenbeautystudio.com.co

LOG_LEVEL=info
