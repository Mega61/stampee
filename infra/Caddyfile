# Three sites, all behind auto-HTTPS (Let's Encrypt). The {$VAR} substitutions
# are read from the compose env, so you do not edit this file per environment.
# Set SPA_DOMAIN / API_DOMAIN / CMS_DOMAIN / ACME_EMAIL in the root .env.

{
    email {$ACME_EMAIL}
}

{$SPA_DOMAIN} {
    encode zstd gzip
    root * /srv/spa
    try_files {path} /index.html
    file_server
    # SPA assets are content-hashed by Vite; cache hard.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

{$API_DOMAIN} {
    reverse_proxy api:3001
}

# Strapi is not part of this stack yet. Uncomment when you wire it up.
