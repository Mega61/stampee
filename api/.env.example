# Stampee API — copy to .env and fill in.
NODE_ENV=development
PORT=3001
SPA_ORIGIN=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3001

# Postgres
DATABASE_URL=postgres://loyalty_user:loyalty_pw@localhost:5433/appdb
PG_POOL_SIZE=10

# JWT — both secrets MUST be >=32 chars in any environment
JWT_ACCESS_SECRET=change-me-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Passwords / PINs
BCRYPT_COST=12
PIN_BCRYPT_COST=10

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Stampee <no-reply@localhost>
# 'console' logs links to stdout; 'resend' calls the real API; 'test' collects in-memory.
EMAIL_ADAPTER=console

# Google Cloud Storage
GCS_BUCKET=
GCS_PROJECT_ID=
# Authentication uses Application Default Credentials only.
# Production: rely on the VM's attached service account (no env value needed).
# Local dev: `gcloud auth application-default login --impersonate-service-account=<sa>@<project>.iam.gserviceaccount.com`
# Do NOT use a JSON key file — org policy disables `iam.disableServiceAccountKeyCreation`.
GOOGLE_APPLICATION_CREDENTIALS=
GCS_PUBLIC_HOST=https://storage.googleapis.com

# Google Workspace SSO ("Sign in with Google"). Leave empty to disable.
# GOOGLE_CLIENT_ID is the OAuth Web client ID (same value baked into the SPA).
# GOOGLE_WORKSPACE_DOMAIN is the allowed Workspace domain(s); consumer Gmail is rejected.
GOOGLE_CLIENT_ID=
GOOGLE_WORKSPACE_DOMAIN=goldenbeautystudio.com.co

# Logging
LOG_LEVEL=info
