# App
VITE_APP_URL=http://localhost:5173

# Stampee API (required) — points at the self-hosted Fastify backend in api/
VITE_API_URL=http://localhost:3001

# Optional: Support email shown in app
# VITE_SUPPORT_EMAIL=support@example.com

# Optional: Google OAuth Web client ID for "Sign in with Google".
# Baked into the SPA bundle at build time (Vite inlines VITE_*). Leave empty to
# hide the Google button. See docs/QUICKSTART.md §8.
VITE_GOOGLE_CLIENT_ID=
